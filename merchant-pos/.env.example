# ────────────────────────────────────────────────────────────────────────────
#  merchant-pos — Next.js app environment (dev / non-docker)
# ────────────────────────────────────────────────────────────────────────────
#
# For containerised deployments these variables come from docker/.env.{mainnet,preprod}
# via docker-compose. Use this file only when running `pnpm dev` outside docker.

# Cardano network
CARDANO_NETWORK=preprod
NEXT_PUBLIC_CARDANO_NETWORK=preprod

# Blockfrost (browser + server)
BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0
BLOCKFROST_KEY=
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID=

# Postgres connection string used by drizzle-orm
DATABASE_URL=postgres://hydra_pos:hydra_pos@localhost:5432/hydra_pos

# Hydra node (filled in by the orchestrator once a head is open)
HYDRA_ENABLE=false
HYDRA_NODE_HOST=localhost
HYDRA_NODE_PORT=4001
HYDRA_NODE_SECURE=false
HYDRA_HEADS_DIR=../docker/heads
HYDRA_CONFIG_DIR=../hydra-config
HYDRA_PROTOCOL_PARAMS=../hydra-config/protocol-parameters.json
HYDRA_KEYS_ROOT=../hydra-config/keys

# Server-side AES-GCM key for the customer L2 spend-key vault.
# Generate with: openssl rand -hex 32
HPOS_KEY_SECRET=

# Operator BIP-39 mnemonic for L1 fee-fuel funding (NOT customer custody).
WALLET_SEED_PHRASE=

# Basic auth for the merchant dashboard (required when hosting publicly).
SITE_PASSWORD_MERCHANT=

# Public URL the customer page lives at (used for QR codes). Leave blank
# for relative URLs.
NEXT_PUBLIC_CUSTOMER_BASE_URL=
