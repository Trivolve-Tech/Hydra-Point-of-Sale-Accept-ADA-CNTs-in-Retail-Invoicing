# ────────────────────────────────────────────────────────────────────────────
#  Hydra Point-of-Sale — MAINNET environment template
# ────────────────────────────────────────────────────────────────────────────
#
#   1. Copy this file to docker/.env.mainnet
#   2. Fill in real values (never commit .env.mainnet — it's gitignored)
#   3. docker compose --env-file docker/.env.mainnet \
#        -f docker/docker-compose.mainnet.yml up -d
#
# WARNING: this stack moves real ADA on Cardano mainnet. Treat every secret
#          here like a production database password.

# ────────────── Cardano network selection ──────────────
CARDANO_NETWORK=mainnet
NEXT_PUBLIC_CARDANO_NETWORK=mainnet

# Where the cardano-node will store its blockchain copy on the host. The
# default keeps it inside the repo working tree; switch to an absolute path
# on a dedicated volume for a real deployment (mainnet chain is ~150 GB).
CARDANO_DATA_DIR=./data/cardano-mainnet

# ────────────── Blockfrost (mandatory for L1 submission paths) ──────────────
# The browser bundle reads NEXT_PUBLIC_BLOCKFROST_PROJECT_ID; the server
# code reads BLOCKFROST_KEY. They can be the same id.
BLOCKFROST_URL=https://cardano-mainnet.blockfrost.io/api/v0
BLOCKFROST_KEY=<your-mainnet-blockfrost-project-id>
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID=<your-mainnet-blockfrost-project-id>

# ────────────── Postgres ──────────────
# Drizzle migrations run on first boot of the merchant-pos service.
DATABASE_URL=postgres://hydra_pos:<strong-db-password>@postgres:5432/hydra_pos
POSTGRES_USER=hydra_pos
POSTGRES_PASSWORD=<strong-db-password>
POSTGRES_DB=hydra_pos

# ────────────── Hydra runtime ──────────────
HYDRA_ENABLE=true
HYDRA_NODE_HOST=merchant-node
HYDRA_NODE_PORT=4001
HYDRA_NODE_SECURE=false

# Where the per-head docker-compose YAML files are written by the orchestrator,
# and where shared hydra-node config + protocol-parameters.json live.
HYDRA_HEADS_DIR=./docker/heads
HYDRA_CONFIG_DIR=./hydra-config
HYDRA_PROTOCOL_PARAMS=./hydra-config/protocol-parameters.json
HYDRA_KEYS_ROOT=./hydra-config/keys

# Hydra mainnet reference-script transaction IDs (chained Init/Commit/Abort
# script publish txns from the cardano-scaling team). Update these only when
# the official Hydra mainnet contracts roll forward.
HYDRA_SCRIPTS_TX_ID=2c6cff509c1849407f40aa00df2bea8a9bc55f294b19fb229edf9e194d5e8b67,7ef58b5694fd89dedf5b47f64489d5f318df710c0cc8ba5a291d96d180a21349,aedd1e9fce035a743fbbaf7385a2a2b774397bdf995aafc6d4c01d9e6a534e28

# ────────────── Server-side custody material ──────────────
# Per-customer L2 spend keys are AES-256-GCM encrypted at rest in Postgres,
# using this server-side secret as the key-derivation input. ROTATE if
# leaked — every existing customer profile must then be re-bootstrapped.
# Generate with: openssl rand -hex 32
HPOS_KEY_SECRET=<openssl rand -hex 32>

# Operator BIP-39 mnemonic used to pre-fund the per-head L1 fee-fuel addresses
# (see scripts/derive-merchant-addresses.ts). NOT used for any customer-funds
# custody. Keep in a secrets manager and inject at runtime.
WALLET_SEED_PHRASE=<24-word-mainnet-mnemonic-for-fee-funding-only>

# ────────────── Site auth + tunnel (optional) ──────────────
# Basic-auth password for the merchant dashboard. MUST be set — middleware
# fails-closed when this is empty.
SITE_PASSWORD_MERCHANT=<strong-merchant-dashboard-password>

# Public URL of the customer page (printed into QR codes shown on the
# merchant dashboard). Leave blank to use the request host.
NEXT_PUBLIC_CUSTOMER_BASE_URL=
