# Hydra Point-of-Sale — MAINNET environment template
#
# Copy to docker/.env.mainnet (gitignored), fill in real values, then run:
#   docker compose -f docker/docker-compose.mainnet.yml up -d
#
# Real ADA. Do not commit this file once populated.

# Blockfrost MAINNET project id and base URL.
BLOCKFROST_KEY=mainnetXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BLOCKFROST_URL=https://cardano-mainnet.blockfrost.io/api/v0

# Server-side Cardano network selector. Must be `mainnet` for this compose
# file; the merchant-pos build refuses to expose its E2E wallet-addresses
# endpoint unless E2E_ENABLED=true is ALSO set (and it must not be).
CARDANO_NETWORK=mainnet

# Operator wallet seed used by the merchant-pos backend for the L1
# Hydra-commit / fanout side. Store in a secret manager and inject at runtime;
# do not put a real seed into this template.
WALLET_SEED_PHRASE=your twenty-four word mainnet mnemonic goes here

# Browser-exposed Cardano network selector (CIP-30 wallet config).
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID=mainnetXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_CARDANO_NETWORK=mainnet
