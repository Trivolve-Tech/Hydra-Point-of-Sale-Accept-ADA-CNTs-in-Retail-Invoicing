# ────────────────────────────────────────────────────────────────────────────
#  Hydra Point-of-Sale — PREPROD testnet environment template
# ────────────────────────────────────────────────────────────────────────────
#
# Same shape as .env.mainnet.example, with Cardano network selectors flipped
# to preprod and Blockfrost endpoints pointing at the preprod project.
# Use this for end-to-end testing with faucet-funded wallets before
# committing real ADA.

CARDANO_NETWORK=preprod
NEXT_PUBLIC_CARDANO_NETWORK=preprod
CARDANO_DATA_DIR=./data/cardano-preprod

BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0
BLOCKFROST_KEY=<your-preprod-blockfrost-project-id>
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID=<your-preprod-blockfrost-project-id>

DATABASE_URL=postgres://hydra_pos:hydra_pos@postgres:5432/hydra_pos
POSTGRES_USER=hydra_pos
POSTGRES_PASSWORD=hydra_pos
POSTGRES_DB=hydra_pos

HYDRA_ENABLE=true
HYDRA_NODE_HOST=merchant-node
HYDRA_NODE_PORT=4001
HYDRA_NODE_SECURE=false
HYDRA_HEADS_DIR=./docker/heads
HYDRA_CONFIG_DIR=./hydra-config
HYDRA_PROTOCOL_PARAMS=./hydra-config/protocol-parameters.json
HYDRA_KEYS_ROOT=./hydra-config/keys
# Preprod hydra-scaling reference scripts (check upstream for current values).
HYDRA_SCRIPTS_TX_ID=<comma-separated-preprod-script-txids>

HPOS_KEY_SECRET=<openssl rand -hex 32>
WALLET_SEED_PHRASE=<24-word-preprod-mnemonic>

SITE_PASSWORD_MERCHANT=<dev-merchant-password>
NEXT_PUBLIC_CUSTOMER_BASE_URL=
